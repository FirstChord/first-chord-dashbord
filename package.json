    "pretest:admin": "node scripts/generate-configs.js --no-backup",
    "test:admin": "node --test tests/admin/*.test.mjs",
    "sync-admin-tutors": "node scripts/sync-admin-tutors.js",
    "backup:sheets": "node scripts/backup-sheets-tabs.mjs",
    "restore:drill": "node scripts/restore-drill.mjs",
    "ensure:state-tabs": "node scripts/ensure-state-tabs.mjs",
    "ensure:practice-delivery-claims": "node scripts/ensure-practice-delivery-claims.mjs",
