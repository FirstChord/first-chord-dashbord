# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/lib/generated/prisma

# config backups (local only)
/backups/

# local-only generated/student credential overrides
/lib/config/theta-credentials.js
/lib/config/theta-credentials.local.js

# derived config — regenerated by scripts/generate-configs.js on every dev/build/deploy.
# Edit lib/config/students-registry.js (canonical) instead; these are build artifacts.
/lib/config/instruments.js
/lib/soundslice-mappings.js
/lib/student-helpers.js
/lib/student-url-mappings.js
